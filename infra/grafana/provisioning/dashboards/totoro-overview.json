{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Service Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=~\"identity-service|core-service|social-service|gateway-service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "title": "HTTP Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=~\"identity-service|core-service|social-service|gateway-service\"}[1m])",
          "legendFormat": "{{job}} {{method}} {{uri}}"
        }
      ]
    },
    {
      "title": "HTTP Response Time p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=~\"identity-service|core-service|social-service|gateway-service\"}[5m]))*1000",
          "legendFormat": "{{job}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=~\"identity-service|core-service|social-service|gateway-service\"}",
          "legendFormat": "{{job}} {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{job=~\"core-service|social-service\"}",
          "legendFormat": "{{name}} = {{state}}"
        }
      ]
    },
    {
      "title": "Resilience4j — Failed Call Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{kind=\"failed\",job=~\"core-service|social-service\"}[5m])",
          "legendFormat": "{{name}} failed/sec"
        }
      ]
    },
    {
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"identity-service|core-service|social-service\"}",
          "legendFormat": "{{job}} active"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["totoro", "microservices", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ToToRo Microservices Overview",
  "uid": "totoro-overview"
}
