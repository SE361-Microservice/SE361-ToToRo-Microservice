# =========================================================================
# ToToRo Microservices Environment Variables Template
# =========================================================================

# ======= GATEWAY CONFIGURATION =======
GATEWAY_PORT=8080

# ======= SERVICE PORTS =======
IDENTITY_SERVICE_PORT=8081
CORE_SERVICE_PORT=8082
SOCIAL_SERVICE_PORT=8083

# ======= DATABASES CONFIGURATION (LOCAL DOCKER COMPOSE) =======
IDENTITY_DB_URL=jdbc:postgresql://localhost:5433/identity_db
IDENTITY_DB_USERNAME=postgres
IDENTITY_DB_PASSWORD=postgres

CORE_DB_URL=jdbc:postgresql://localhost:5434/core_db
CORE_DB_USERNAME=postgres
CORE_DB_PASSWORD=postgres

SOCIAL_DB_URL=jdbc:postgresql://localhost:5435/social_db
SOCIAL_DB_USERNAME=postgres
SOCIAL_DB_PASSWORD=postgres

# ======= CLOUD DATABASES CONFIGURATION (NEON PRODUCTION/STAGING) =======
# Thay thế các URL này bằng URL kết nối lấy từ neon.tech nếu không chạy local DB.
# NEON_IDENTITY_DB_URL=postgresql://<user>:<password>@<host>/identity_db?sslmode=require
# NEON_CORE_DB_URL=postgresql://<user>:<password>@<host>/core_db?sslmode=require
# NEON_SOCIAL_DB_URL=postgresql://<user>:<password>@<host>/social_db?sslmode=require

# ======= KAFKA CONFIGURATION =======
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ======= SECURITY & TOKENS =======
# Generate key bằng: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ======= INTERNAL SERVICE CALLS URLS =======
IDENTITY_SERVICE_URL=http://localhost:8081
CORE_SERVICE_URL=http://localhost:8082
SOCIAL_SERVICE_URL=http://localhost:8083

# ======= AI SERVICE SETTINGS =======
AI_SERVICE_URL=http://localhost:8000
INTERNAL_API_KEY=your_internal_api_key_here

# ======= MAIL CONFIGURATION (OPTIONAL FOR DEV) =======
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ======= OBSERVABILITY =======
JAEGER_ENDPOINT=http://localhost:4318/v1/traces
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
