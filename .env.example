# =============================================================================
# .env.example — ToToRo Microservices Google Cloud Run Deploy
# =============================================================================
# Copy file này thành .env và điền giá trị thực tế
# KHÔNG commit file .env lên Git
#
# Tech Stack:
#   Backend  → Google Cloud Run (4 services deployed independently)
#   Database → Neon PostgreSQL (3 projects / branches)
#   Kafka    → Aiven Apache Kafka (Always Free Tier)
#   Frontend → Vercel (Next.js / React)
# =============================================================================


# =============================================================================
# [SHARED CONFIGURATION]
# =============================================================================

# JWT secret key (Base64 encoded, at least 256-bit)
# Generate: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_at_least_32_chars


# =============================================================================
# [NEON POSTGRESQL] — https://neon.tech
# Create 3 separate projects/databases (or 1 project with 3 databases)
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
# =============================================================================

# identity-service database URL
IDENTITY_DB_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/identity_db?sslmode=require

# core-service database URL
CORE_DB_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/core_db?sslmode=require

# social-service database URL
SOCIAL_DB_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/social_db?sslmode=require


# =============================================================================
# [AIVEN KAFKA] — https://aiven.io (Always Free Tier, No CC Required)
# Select SASL/SCRAM mechanism under connection information
# =============================================================================

# Aiven Kafka bootstrap server URL
# Format: <service-name>-<project-name>.aivencloud.com:<sasl-port>
KAFKA_BOOTSTRAP_SERVERS=totoro-kafka-myproject.aivencloud.com:27010

# SASL credentials provided by Aiven console for the default user
KAFKA_SASL_USERNAME=avnadmin
KAFKA_SASL_PASSWORD=your_aiven_kafka_password

# Fixed SASL configurations required for Aiven
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512


# =============================================================================
# [GOOGLE CLOUD RUN SERVICE URLS]
# After deploying services to Cloud Run, replace with their public https:// URLs
# =============================================================================

# Public URL of Identity Service (Cloud Run URL)
# Used by Gateway routing and Core/Social Feign clients
IDENTITY_SERVICE_URL=https://identity-service-xxxxxx-as.a.run.app

# Public URL of Core Service
CORE_SERVICE_URL=https://core-service-xxxxxx-as.a.run.app

# Public URL of Social Service (REST endpoints)
SOCIAL_SERVICE_URL=https://social-service-xxxxxx-as.a.run.app

# Public WebSocket URL of Social Service (wss:// protocol)
SOCIAL_SERVICE_WS_URL=wss://social-service-xxxxxx-as.a.run.app

# Allowed CORS origin - point to your Vercel frontend URL
ALLOWED_ORIGIN=https://totoro-frontend.vercel.app


# =============================================================================
# [IDENTITY SERVICE SPECIFIC ENV VARS]
# =============================================================================
# Database configurations
SPRING_DATASOURCE_URL=${IDENTITY_DB_URL}

# Google OAuth2 configurations (if enabled)
GOOGLE_CLIENT_ID=your_google_oauth2_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth2_client_secret
OAUTH2_REDIRECT_URI=https://gateway-service-xxxxxx-as.a.run.app/api/auth/oauth2/callback

# SMTP Mail settings for email confirmation
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Frontend redirect path after verification
APP_FRONTEND_URL=https://totoro-frontend.vercel.app


# =============================================================================
# [CORE SERVICE SPECIFIC ENV VARS]
# =============================================================================
SPRING_DATASOURCE_URL=${CORE_DB_URL}
SPRING_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}


# =============================================================================
# [SOCIAL SERVICE SPECIFIC ENV VARS]
# =============================================================================
SPRING_DATASOURCE_URL=${SOCIAL_DB_URL}
SPRING_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}


# =============================================================================
# [FRONTEND ENV VARS] — Set directly in Vercel Dashboard
# =============================================================================
# Base Gateway API endpoint
VITE_API_URL=https://gateway-service-xxxxxx-as.a.run.app/api

# Gateway WebSocket endpoint (wss://)
VITE_WS_URL=wss://gateway-service-xxxxxx-as.a.run.app/ws
