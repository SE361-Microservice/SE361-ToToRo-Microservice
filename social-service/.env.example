# ======= SOCIAL SERVICE SPECIFIC CONFIG =======
SERVER_PORT=8083

# Local Database Port: 5435
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5435/social_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Kafka Bootstrap Server
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Cloudinary Integration (for review images & chat media)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Feign Client URLs
IDENTITY_SERVICE_URL=http://localhost:8081
CORE_SERVICE_URL=http://localhost:8082

# Mail Server Config (for email notifications)
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# OpenTelemetry Tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
