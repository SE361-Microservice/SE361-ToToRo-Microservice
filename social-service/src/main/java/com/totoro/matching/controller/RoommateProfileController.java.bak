package com.totoro.matching.controller;

import com.totoro.common.dto.PageResponse;import com.totoro.matching.dto.RoommateProfileRequest;
import com.totoro.matching.dto.RoommateProfileResponse;
import com.totoro.matching.dto.RoommateSearchRequest;
import com.totoro.matching.service.RoommateProfileService;
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/roommate-profiles")
@RequiredArgsConstructor
public class RoommateProfileController {

    private final RoommateProfileService roommateProfileService;

    @PostMapping("/me")
    public ResponseEntity<RoommateProfileResponse> upsertMyProfile(
            @RequestHeader("X-User-Id") Long userId,
            @Valid @RequestBody RoommateProfileRequest request) {
        return ResponseEntity.ok(roommateProfileService.upsert(String.valueOf(userId), request));
    }

    @GetMapping("/me")
    public ResponseEntity<RoommateProfileResponse> getMyProfile(@RequestHeader("X-User-Id") Long userId) {
        return ResponseEntity.ok(roommateProfileService.getMyProfile(String.valueOf(userId)));
    }

    @DeleteMapping("/me")
    public ResponseEntity<String> deleteMyProfile(@RequestHeader("X-User-Id") Long userId) {
        roommateProfileService.deleteMyProfile(String.valueOf(userId));
        return ResponseEntity.ok("Xóa hồ sơ roommate thành công");
    }

    /**
     * Get a roommate profile by its ID.
     * Used by AI Agent to fetch another user's profile for compatibility scoring.
     */
    @GetMapping("/{id}")
    public ResponseEntity<RoommateProfileResponse> getById(@PathVariable Long id) {
        return ResponseEntity.ok(roommateProfileService.getById(id));
    }

    /**
     * Get a roommate profile by userId.
     * Used by AI Agent to fetch current user's roommate profile using userId.
     */
    @GetMapping("/user/{userId}")
    public ResponseEntity<RoommateProfileResponse> getByUserId(@PathVariable Long userId) {
        return ResponseEntity.ok(roommateProfileService.getByUserId(userId));
    }

    /**
     * Search roommate profiles with lifestyle filters.
     * Used by AI Agent's search_roommates tool.
     */
    @GetMapping("/search")
    public ResponseEntity<PageResponse<RoommateProfileResponse>> search(
            RoommateSearchRequest request,
            @RequestParam(defaultValue = "0") int page,
            @RequestParam(defaultValue = "20") int size) {
        Pageable pageable = PageRequest.of(page, size);
        return ResponseEntity.ok(roommateProfileService.search(request, pageable));
    }
}


